{
  "name": "golden-sungava-homepage",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "sb:start": "pnpx supabase start",
    "sb:stop": "pnpx supabase stop",
    "sb:status": "pnpx supabase status",
    "sb:login": "pnpx supabase login",
    "sb:link": "pnpx supabase link --project-ref $SUPABASE_PROJECT_ID",
    "sb:unlink": "pnpx supabase unlink",
    "db:diff": "pnpx supabase db diff -f",
    "db:migrate": "pnpx supabase migration up",
    "db:reset": "pnpx supabase db reset",
    "db:reset:linked": "pnpx supabase db reset --linked",
    "db:push": "pnpx supabase db push",
    "db-backup": "tsx scripts/db/backup.ts",
    "db-truncate": "tsx scripts/db/truncate.ts",
    "db-restore": "tsx scripts/db/restore.ts",
    "db-backup:reset": "pnpm db-backup && pnpm db:reset",
    "db-backup:reset:restore": "pnpm db-backup && pnpm db:reset && pnpm db-restore",
    "db:gen:types": "pnpx supabase gen types typescript --local > src/types/database.gen.ts",
    "db:dump:local": "pnpx supabase db dump --data-only --file local_data_dump.sql",
    "db:dump:cloud": "pnpx supabase db dump --db-url \"$BACKUP_SUPABASE_DB_URL\" --data-only --file cloud_data_dump.sql"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.90.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.563.0",
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20",
    "@types/pg": "^8.15.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^11.0.0",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "pg": "^8.16.0",
    "supabase": "^2.75.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
